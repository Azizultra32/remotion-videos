node_modules/
out/
source-media/
editor/dist/
.agents-active.json
.env
.env.local
.env.*
!.env.example
brands/*/photos/
brands/*/fonts/
*.mp4
*.webm
*.mov
# audio files used to be gitignored here; they are now tracked via git-LFS
# (see .gitattributes). Keeping this comment as a navigation marker.
.DS_Store
.worktrees/

# Python analysis pipeline transients
__pycache__/
*.pyc
.venv-allin1/
.features_msaf_tmp.json
estimations/

# tsc incremental build cache
*.tsbuildinfo

# current-project marker — bridges editor's SongPicker state to Claude Code
# sessions via `npm run mv:current`. Per-machine UI state, not versioned.
.current-project

# analyze-status per-run transient — written by mv:analyze, consumed by
# the editor's /api/analyze/status SSE. Per-machine, per-run; not versioned.
.analyze-status.json
projects/*/.analyze-status.json

# Subagent leakage: `claude -p` children from mv:analyze sometimes write
# .claude/settings.local.json into a project subdir if their cwd is set
# there. These should never be versioned.
projects/**/.claude/
.claude/scheduled_tasks.lock

# Reference clones of other people's Remotion projects — research only,
# not imported by anything in this repo. Kept on disk for study, not in git.
vendor/
