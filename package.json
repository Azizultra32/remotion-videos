{
  "name": "remotion-videos",
  "version": "1.0.0",
  "description": "Remotion video production + MMX visualization",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render",
    "render": "remotion render",
    "still": "remotion still",
    "test": "vitest run",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write --unsafe .",
    "mv:render": "tsx scripts/cli/mv-render.ts",
    "mv:scaffold": "tsx scripts/cli/mv-scaffold.ts",
    "mv:current": "tsx scripts/cli/mv-current.ts",
    "mv:analyze": "tsx scripts/cli/mv-analyze.ts",
    "mv:seed-beats": "tsx scripts/cli/mv-seed-beats.ts",
    "mv:clear-events": "tsx scripts/cli/mv-clear-events.ts",
    "mv:switch": "tsx scripts/cli/mv-switch.ts",
    "mv:project-init-repo": "tsx scripts/cli/mv-project-init-repo.ts",
    "mv:verify-element": "tsx scripts/verify-element-render.ts",
    "postinstall": "git config core.hooksPath scripts/hooks 2>/dev/null || true"
  },
  "keywords": [],
  "author": "ali",
  "license": "UNLICENSED",
  "dependencies": {
    "@remotion/bundler": "4.0.434",
    "@remotion/cli": "4.0.434",
    "@remotion/media": "4.0.434",
    "@remotion/media-utils": "4.0.434",
    "@remotion/player": "4.0.434",
    "@remotion/renderer": "4.0.434",
    "@remotion/studio": "4.0.434",
    "@remotion/zod-types": "4.0.434",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.434",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.6.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
