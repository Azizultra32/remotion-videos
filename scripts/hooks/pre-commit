#!/usr/bin/env bash
#
# scripts/hooks/pre-commit
#
# Guards the engine/content separation at commit time. Specifically:
#
# 1. src/compositions/elements/_generated-custom-elements.ts is a barrel
#    that mv:render regenerates per render and resets on exit. Under
#    normal exit paths (close handler + SIGINT/SIGTERM/uncaughtException
#    handlers in scripts/cli/mv-render.ts) the reset fires and the file
#    lands back at its tracked empty-stub state. But SIGKILL and OS-level
#    kill -9 can't be caught — the file would stay populated with
#    references to per-project .tsx modules by path. A naive `git add .`
#    or `git commit -a` would sweep that into a commit, polluting the
#    engine with project content and breaking the separation.
#
#    This hook scans the STAGED version of the barrel and rejects the
#    commit if it contains any `_proj_` identifiers. Agents who
#    genuinely need to update the empty-stub header text still can —
#    only imports/references of per-project modules are blocked.
#
# Install (one time, per clone):
#   git config core.hooksPath scripts/hooks
#
# Uninstall:
#   git config --unset core.hooksPath

set -euo pipefail

BARREL_PATH="src/compositions/elements/_generated-custom-elements.ts"

# Is the barrel staged for this commit at all? If not, nothing to check.
if ! git diff --cached --name-only | grep -qx "$BARREL_PATH"; then
  exit 0
fi

# Detect `git add --intent-to-add`: the index records the empty-blob SHA
# (e69de29bb2d1d6434b8b29ae775ad8c2e48c5391 — git's canonical hash for
# empty content), NOT the all-zeros SHA (which is reserved for unmerged
# entries). A prior iteration of this hook checked for zero-SHA and was
# dead code. Round-4 review caught it. Now we detect both (a) the
# empty-blob SHA in the index entry AND (b) the explicit intent-to-add
# flag from `git status --porcelain=v2`, which surfaces IA-marked paths.
# Belt-and-braces — either signal blocks the commit.
EMPTY_BLOB_SHA="e69de29bb2d1d6434b8b29ae775ad8c2e48c5391"
INDEX_SHA="$(git ls-files --stage -- "$BARREL_PATH" | awk '{print $2}')"
STATUS_FLAGS="$(git status --porcelain=v2 -- "$BARREL_PATH" | head -1 | awk '{print $2}')"
if [ "$INDEX_SHA" = "$EMPTY_BLOB_SHA" ] || echo "$STATUS_FLAGS" | grep -q 'A'; then
  cat >&2 <<EOF
[pre-commit] BLOCKED: $BARREL_PATH is staged as --intent-to-add or empty blob.

This file is auto-generated by mv:render and shouldn't be --intent-to-add
staged. Either stage the real empty-stub content or unstage entirely:

  git reset HEAD $BARREL_PATH
  npx tsx -e "import {resetCustomElementsBarrel} from './scripts/cli/custom-elements-barrel'; resetCustomElementsBarrel('.')"
  git add $BARREL_PATH   # if you really meant to commit the empty stub

Or, for a one-off override:   git commit --no-verify
EOF
  exit 1
fi

# Read the STAGED version (not the working-tree version — those can diverge).
STAGED_CONTENT="$(git show ":$BARREL_PATH")"

if echo "$STAGED_CONTENT" | grep -q '_proj_'; then
  cat >&2 <<EOF
[pre-commit] BLOCKED: $BARREL_PATH is staged with per-project imports (\`_proj_*\`).

This file is auto-generated by mv:render before each bundle and reset on
exit. If you're seeing \`_proj_*\` identifiers here, a previous render was
killed mid-flight (SIGKILL or similar — signal handlers couldn't fire)
and its barrel state leaked into your staging area. This would commit
project-specific module paths into the engine — breaking the engine/
content separation.

To fix, from the repo root:

  npx tsx -e "import {resetCustomElementsBarrel} from './scripts/cli/custom-elements-barrel'; resetCustomElementsBarrel('.')"
  git add $BARREL_PATH

Then try your commit again. If you genuinely need to modify the barrel
beyond the empty stub, this hook is pointing at something you should
rethink — the barrel is not meant to be authored by hand.

Or, for a one-off override:   git commit --no-verify
EOF
  exit 1
fi

exit 0
